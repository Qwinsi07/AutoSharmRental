# ================================================================
# SUPABASE CONFIGURATION
# ================================================================
# These values are PUBLIC (visible in browser bundle)
# Get these from: Supabase Dashboard → Settings → API

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous (public) key - used for client-side queries
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here-starting-with-ey...


# ================================================================
# ADMIN AUTHENTICATION
# ================================================================
# These values are PRIVATE (server-side only)
# DO NOT expose these to the browser

# Admin panel login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here

# Optional: Service role key for advanced server operations
# NEVER use this in frontend code!
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# ================================================================
# LOCAL DEVELOPMENT
# ================================================================
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your actual values from Supabase
# 3. Add .env.local to .gitignore (already done - verify with: cat .gitignore)
# 4. Restart your dev server: npm run dev
#
# NEXT_PUBLIC_SUPABASE_URL should look like:
#   https://YOUR_PROJECT_ID.supabase.co
#
# NEXT_PUBLIC_SUPABASE_ANON_KEY should start with: ey...


# ================================================================
# NETLIFY DEPLOYMENT
# ================================================================
# Add these environment variables in Netlify:
# 1. Go to: https://app.netlify.com → Your Site → Site settings → Build & deploy → Environment
# 2. Click "Edit variables"
# 3. Add all 4 variables:
#    - NEXT_PUBLIC_SUPABASE_URL
#    - NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - ADMIN_USERNAME
#    - ADMIN_PASSWORD
# 4. Do NOT add a .env.local or .env file - use Netlify's UI only!
# 5. Redeploy after adding variables (click "Trigger deploy")


# ================================================================
# SECURITY BEST PRACTICES
# ================================================================
# PUBLIC VARIABLES (safe to commit - visible in browser):
# - All variables starting with NEXT_PUBLIC_*
# - These are bundled into your frontend code
# - Examples: NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# PRIVATE VARIABLES (NEVER commit - server-side only):
# - All other variables (ADMIN_USERNAME, ADMIN_PASSWORD, etc.)
# - These are used only on the server
# - .gitignore prevents accidental commits
#
# NEVER:
# - Commit .env.local or any .env files to GitHub
# - Share your API keys or passwords
# - Use NEXT_PUBLIC_ prefix for sensitive data
